# RabbitMQ connection config (local development)
# DO NOT commit this file with real credentials - add to .gitignore
rabbitmq.host=localhost
rabbitmq.port=5672
rabbitmq.user=guest
rabbitmq.pass=guest
rabbitmq.exchange=chat.exchange

# Prefetch count per consumer channel (messages in-flight before ack).
# Raise if queue depth stays high; lower if memory usage is too high.
rabbitmq.prefetch=50

# Redis connection (used for Pub/Sub broadcast to server-v2 instances)
redis.host=localhost
redis.port=6379

# Jedis connection pool sizing.
# maxTotal should be >= (consumer.threads * 2) to avoid pool exhaustion.
# maxWaitMs: max time (ms) a thread waits for a free connection; 2000 recommended.
redis.pool.maxTotal=20
redis.pool.maxWaitMs=2000

# Number of RoomConsumer threads.
# Each thread handles (ROOM_COUNT / consumer.threads) rooms.
# 10 threads = 2 rooms/thread (default). 20 threads = 1 room/thread (max parallelism).
# If raising to 20, also set redis.pool.maxTotal=40.
consumer.threads=10
